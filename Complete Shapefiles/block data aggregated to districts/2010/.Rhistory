print("sim complete")
setwd(paste0(wd,"/RB Seeded Sims/" ))
#Save resulting plans
saveRDS(rb_plans, file=paste0(substr(filenames_blocks[i], 0, nchar(filenames_blocks[i])-7), "_plans.rds"))
}

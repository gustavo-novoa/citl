# Self Reported Housing Burden -----
crbo$owner_exp<- gsub("\\$|,|-", "", crbo$owner_exp)
crbo$owner_exp_mid<-sapply(crbo$owner_exp, function(x) {
ifelse(x == "" | is.na(x), NA,
mean(as.numeric(strsplit(x, "\\s+")[[1]])))
})
crbo$owner_exp_mid<-unname(crbo$owner_exp_mid)
crbo$rent_exp<- gsub("\\$|,|-", "", crbo$rent_exp)
crbo$rent_exp_mid<-sapply(crbo$rent_exp, function(x) {
ifelse(x == "" | is.na(x), NA,
mean(as.numeric(strsplit(x, "\\s+")[[1]])))
})
crbo$rent_exp_mid<-unname(crbo$rent_exp_mid)
crbo$housing_burden<-coalesce(crbo$owner_exp_mid, crbo$rent_exp_mid)/(crbo$income/12)
crbo$owner_exp_mid<-crbo$owner_exp_mid/(crbo$income/12)
crbo$housing_burden_trunc<-ifelse(crbo$housing_burden>1, NA, crbo$housing_burden)
# Full column
hbl30<-lmer(data=crbo, be_100_l30 ~ housing_burden +respondent_bin + (1|CSA_NAME))
hbmr<-lmer(data=crbo, be_0 ~ housing_burden +respondent_bin + (1|CSA_NAME))
tab_model(hbl30, hbmr)
# Add FT poor
hbl30ft<-lmer(data=crbo, be_100_l30 ~ housing_burden +respondent_bin + rescale(ft_poor)+(1|CSA_NAME))
hbmrft<-lmer(data=crbo, be_0 ~ housing_burden +respondent_bin + rescale(ft_poor)+(1|CSA_NAME))
tab_model(hbl30ft, hbmrft)
tab_model(hbl30ft, hbmrft,
ci.hyphen = ":", show.icc = FALSE,
show.re.var = FALSE, collapse.ci = TRUE,
dv.labels = c("<30% AMI", "Market Rate"),
p.style='stars',
pred.labels=c("Intercept",
"Housing Burden (Rescaled)",
"Respondent bin 30-60% AMI [<30%]",
"Respondent bin 60-90% AMI [<30%]",
"Respondent bin 90-120% AMI [<30%]",
"Respondent bin 120-150% AMI [<30%]",
"Respondent bin 150%+ AMI [<30%]",
"FT Low income (Rescaled)"))
# Truncated
hbl30trunc<-lmer(data=crbo, be_100_l30 ~ housing_burden_trunc +respondent_bin + (1|CSA_NAME))
hbmrtrunc<-lmer(data=crbo, be_0 ~ housing_burden_trunc +respondent_bin + (1|CSA_NAME))
tab_model(hbl30trunc, hbmrtrunc)
# Add FT poor
hbl30truncft<-lmer(data=crbo, be_100_l30 ~ rescale(housing_burden_trunc) +respondent_bin + rescale(ft_poor) + (1|CSA_NAME))
hbmrtruncft<-lmer(data=crbo,       be_0 ~ rescale(housing_burden_trunc) +respondent_bin + rescale(ft_poor)+ (1|CSA_NAME))
tab_model(hbl30truncft, hbmrtruncft,
ci.hyphen = ":", show.icc = FALSE,
show.re.var = FALSE, collapse.ci = TRUE,
dv.labels = c("<30% AMI Building Eval", "Market Rate Building Eval"),
p.style='stars',
pred.labels=c("Intercept",
"Housing Burden (truncated and rescaled)",
"Respondent bin 30-60% AMI [<30%]",
"Respondent bin 60-90% AMI [<30%]",
"Respondent bin 90-120% AMI [<30%]",
"Respondent bin 120-150% AMI [<30%]",
"Respondent bin 150%+ AMI [<30%]",
"FT Low income (Rescaled)"))

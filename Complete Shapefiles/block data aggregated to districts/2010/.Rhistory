# Middle Income ----
crbo$mid_income<-ifelse(crbo$respondent_bin=='60_90'|crbo$respondent_bin=='90_120',1,0)
tab_model(lmer(data=crbo, be_100_90_120~rescale(ft_mid)+ mid_income+ (1|CSA_NAME)),
order.terms=c(2,3,1), ci.hyphen = ":", dv.labels = "Middle-Income Building Evaluation",

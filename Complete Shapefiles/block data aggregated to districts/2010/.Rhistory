# Visualize RR vs FT Poor ----
crbo$respondent_bin<-factor(crbo$respondent_bin,
levels=c("l30", "30_60", "60_90", "90_120", "120_150","150+"))
crbo$respondent_bin <- relevel(crbo$respondent_bin, ref = "150+")
rrvft<-lmer(data=crbo, be_100_l30 ~ arm::rescale(rrs1) + arm::rescale(ft_poor) + respondent_bin + (1|CSA_NAME))
rrvmr<-lmer(data=crbo, be_0 ~ arm::rescale(rrs1) + arm::rescale(ft_rich) + respondent_bin + (1|CSA_NAME))
tab_model(rrvft, rrvmr, collapse.ci = TRUE, p.style ='stars',
pred.labels = c("Intercept","Racial Resentment (Rescaled)","FT Low Income (Rescaled)",
"Respondent Bin <60% AMI [150%+]", "Respondent Bin 60-90% AMI [150%+]",
"Respondent Bin 90-120% AMI [150%+]","Respondent Bin 120-150% AMI [150%+]",
"FT High Income (Rescaled)"),
show.re.var = FALSE, show.icc = FALSE, dv.labels = c("Support for <30% AMI Building",
"Support for Market Rate Building"),
order.terms=c(1,2,8,3,4,5,6,7))
crbo$respondent_bin <- relevel(crbo$respondent_bin, ref = "90_120")
rrvft <- lmer(data=crbo, be_100_l30 ~ arm::rescale(rrs1) + arm::rescale(ft_poor) + respondent_bin + (1|CSA_NAME))
# Get the model coefficients and variance-covariance matrix
coef_summary <- summary(rrvft)
coef_rr <- fixef(rrvft)["arm::rescale(rrs1)"]
coef_ft_poor <- fixef(rrvft)["arm::rescale(ft_poor)"]
intercept <- fixef(rrvft)["(Intercept)"]
# Get variance-covariance matrix for fixed effects
vcov_matrix <- vcov(rrvft)
# Create prediction data frames
# For ft_poor effect (holding rr at its mean)
ft_poor_range <- seq(min(crbo$ft_poor, na.rm = TRUE),
max(crbo$ft_poor, na.rm = TRUE),
length.out = 100)
rr_mean <- mean(crbo$rr, na.rm = TRUE)
# Calculate rescaling parameters manually (arm::rescale divides by 2*SD)
ft_poor_center <- mean(crbo$ft_poor, na.rm = TRUE)
ft_poor_scale <- 2 * sd(crbo$ft_poor, na.rm = TRUE)
# Rescale the range values
ft_poor_range_rescaled <- (ft_poor_range - ft_poor_center) / ft_poor_scale
# For rr effect (holding ft_poor at its mean)
rr_range <- seq(min(crbo$rr, na.rm = TRUE),
max(crbo$rr, na.rm = TRUE),
length.out = 100)
ft_poor_mean <- mean(crbo$ft_poor, na.rm = TRUE)
# Calculate rescaling parameters for rr
rr_center <- mean(crbo$rr, na.rm = TRUE)
rr_scale <- 2 * sd(crbo$rr, na.rm = TRUE)
# Rescale the range values
rr_range_rescaled <- (rr_range - rr_center) / rr_scale
ft_poor_mean_rescaled <- (ft_poor_mean - ft_poor_center) / ft_poor_scale
rr_mean_rescaled <- (rr_mean - rr_center) / rr_scale
# Calculate predictions for ft_poor
pred_ft_poor <- intercept + coef_ft_poor * ft_poor_range_rescaled +
coef_rr * rr_mean_rescaled
# Calculate standard errors for ft_poor predictions
se_ft_poor <- sapply(ft_poor_range_rescaled, function(x) {
# Design matrix for this prediction
X <- c(1, rr_mean_rescaled, x, 0, 0, 0, 0,0)  # Intercept, rr, ft_poor, respondent_bins
# Standard error: sqrt(X' * Vcov * X)
as.numeric(sqrt(t(X) %*% vcov_matrix %*% X))
})
# 95% confidence intervals
ci_ft_poor_lower <- pred_ft_poor - 1.96 * se_ft_poor
ci_ft_poor_upper <- pred_ft_poor + 1.96 * se_ft_poor
# Calculate predictions for rr
pred_rr <- intercept + coef_rr * rr_range_rescaled +
coef_ft_poor * ft_poor_mean_rescaled
# Calculate standard errors for rr predictions
se_rr <- sapply(rr_range_rescaled, function(x) {
# Design matrix for this prediction
X <- c(1, x, ft_poor_mean_rescaled, 0, 0, 0,0, 0)  # Intercept, rr, ft_poor, respondent_bins
# Standard error: sqrt(X' * Vcov * X)
as.numeric(sqrt(t(X) %*% vcov_matrix %*% X))
})
# 95% confidence intervals
ci_rr_lower <- pred_rr - 1.96 * se_rr
ci_rr_upper <- pred_rr + 1.96 * se_rr
# Create data frames for plotting
df_ft_poor <- data.frame(
ft_poor = ft_poor_range,
b100_l30 = pred_ft_poor,
ci_lower = ci_ft_poor_lower,
ci_upper = ci_ft_poor_upper,
variable = "ft_poor"
)
df_rr <- data.frame(
rr = rr_range,
b100_l30 = pred_rr,
ci_lower = ci_rr_lower,
ci_upper = ci_rr_upper,
variable = "rr"
)
# Plot with confidence intervals
ggplot() +
geom_ribbon(data = df_ft_poor,
aes(x = ft_poor, ymin = ci_lower, ymax = ci_upper),
fill = "blue", alpha = 0.2) +
geom_line(data = df_ft_poor,
aes(x = ft_poor, y = b100_l30, color = "ft_poor"),
linewidth = 1) +
geom_ribbon(data = df_rr,
aes(x = rr, ymin = ci_lower, ymax = ci_upper),
fill = "red", alpha = 0.2) +
geom_line(data = df_rr,
aes(x = rr, y = b100_l30, color = "rr"),
linewidth = 1, linetype = "dashed") +
scale_color_manual(name = "Predictor",
values = c("ft_poor" = "blue", "rr" = "red"),
labels = c("FT Low Income", "Racial Resentment")) +
labs(x = "Symbolic Score",
y = "Predicted Support for <30% AMI Building",
title = "Estimated Support for Poorest Building by Symbolic Predictors") +
theme_minimal() +
theme(legend.position = "bottom")+ylim(0,1)

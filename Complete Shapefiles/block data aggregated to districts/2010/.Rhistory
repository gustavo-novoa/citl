pred.labels=c("Intercept","Respondent Bin 30-60% [<30]",
"Respondent Bin 60-90% [<30]", "Respondent Bin 90-120% [<30]",
"Respondent Bin 120-150% [<30]", "Respondent Bin 150%+ [<30]",
"Trump Voter", "FT Low Income (Rescaled)", "Super Self-Interested"),
show.re.var = FALSE, show.icc=FALSE, collapse.ci = TRUE, ci.hyphen =":",
p.style='stars', dv.labels="Building Eval <30%")
# RR
tab_model(lmer(data=crbo_rr,b100_l30 ~ respondent_bin + trump + rescale(rr)+ rescale(ft_poor) + ssi+(1|CSA_NAME)),
pred.labels=c("Intercept","Respondent Bin 30-60% [<30]",
"Respondent Bin 60-90% [<30]", "Respondent Bin 90-120% [<30]",
